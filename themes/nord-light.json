  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#4C566A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#5E81AC"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic"
      ],
      "settings": {
        "foreground": "#434C5E"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.interpolated",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#4D7A3A"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "constant.character",
        "constant.other.placeholder",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#946D2A"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.octal"
      ],
      "settings": {
        "foreground": "#8B5C83"
      }
    },
    {
      "scope": [
        "constant.language",
        "variable.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#5E81AC"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function"
      ],
      "settings": {
        "foreground": "#2E7D96"
      }
    },
    {
      "scope": [
        "entity.name.class",
        "entity.name.type.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#1B7C7C"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#1B7C7C"
      }
    },
    {
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#5E81AC"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.parameter",
        "variable.parameter.function"
      ],
      "settings": {
        "foreground": "#2E3440"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "entity.name.constant"
      ],
      "settings": {
        "foreground": "#8B5C83"
      }
    },
    {
      "scope": [
        "meta.property-name",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#1B7C7C"
      }
    },
    {
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#434C5E"
      }
    },
    {
      "scope": [
        "punctuation.section.embedded",
        "variable.interpolation"
      ],
      "settings": {
        "foreground": "#946D2A"
      }
    },
    {
      "scope": [
        "support.variable"
      ],
      "settings": {
        "foreground": "#2E3440"
      }
    },
    {
      "scope": [
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#ECEFF4"
      }
    },
    {
      "scope": [
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#ECEFF4"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading entity.name"
      ],
      "settings": {
        "foreground": "#5E81AC",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "foreground": "#2E3440",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "foreground": "#2E3440",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "markup.quote",
      "settings": {
        "foreground": "#1B7C7C"
      }
    },
    {
      "scope": [
        "markup.raw",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#4D7A3A"
      }
    },
    {
      "scope": [
        "markup.inserted",
        "punctuation.definition.inserted",
        "meta.diff.header.to-file"
      ],
      "settings": {
        "foreground": "#4D7A3A"
      }
    },
    {
      "scope": [
        "markup.deleted",
        "punctuation.definition.deleted",
        "meta.diff.header.from-file"
      ],
      "settings": {
        "foreground": "#BF616A"
      }
    },
    {
      "scope": [
        "markup.changed",
        "punctuation.definition.changed"
      ],
      "settings": {
        "foreground": "#D08770"
      }
    },
    {
      "scope": [
        "markup.list",
        "punctuation.definition.list.begin.markdown"
      ],
      "settings": {
        "foreground": "#BF616A"
      }
    },
    {
      "scope": [
        "constant.other.reference.link",
        "string.other.link",
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#5E81AC",
        "fontStyle": "underline"
      }
    },
    {
      "scope": "meta.diff.range",
      "settings": {
        "foreground": "#8B5C83",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "meta.diff.header",
      "settings": {
        "foreground": "#5E81AC"
      }
    },
    {
      "scope": "meta.separator",
      "settings": {
        "foreground": "#5E81AC",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "token.info-token",
      "settings": {
        "foreground": "#5E81AC"
      }
    },
    {
      "scope": "token.warn-token",
      "settings": {
        "foreground": "#D08770"
      }
    },
    {
      "scope": "token.error-token",
      "settings": {
        "foreground": "#BF616A"
      }
    },
    {
      "scope": "token.debug-token",
      "settings": {
        "foreground": "#8B5C83"
      }
    }
  ]
